# EDGE stack (redis/minio)
REDIS_HOST=edge-redis
REDIS_PORT=6379
REDIS_PASSWORD=superpassword

MINIO_URL=edge-minio:9000
MINIO_ACCESS_KEY=access_key
MINIO_SECRET_KEY=secret_key
MINIO_SECURE=false

# Shared secret for global ingest validation
SECRET_API_KEY=super_secret_api_key

GLOBAL_TXT_PATH=/data/global_ingest_batches.jsonl

# Edge camera sources: indices or rtsp urls separated by ';' or ','
CAMERA_SOURCES=rtsp://host.docker.internal:554/live
EDGE_ID=edge-1
BATCH_SIZE=100
MAX_IN_FLIGHT=4

# Celery worker concurrency
CELERY_YOLO_CONCURRENCY=2
CELERY_RECOGNIZER_CONCURRENCY=2
CELERY_EMOTIONS_CONCURRENCY=2

